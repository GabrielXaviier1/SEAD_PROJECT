{
  "compilerOptions": {
    /* Configurações de Saída e Alvo */
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    
    
    /* Integração e Ambiente */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    
    /* Isso aqui mata o erro do 'process' */
    "types": ["node"],
    
    /* Isso aqui mata o erro do 'const' e 'export' */
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}